#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  has-session)
    exit 0
    ;;
  list-panes)
    printf 'fake-session:frontend\tcodex-aarch64-a\t0\n'
    ;;
  capture-pane)
    printf '%s\n' "${TMUX_FIXTURE_CAPTURE:-fake Codex pane waiting at prompt}"
    ;;
  load-buffer)
    exit 0
    ;;
  paste-buffer)
    if [ -n "${TMUX_FIXTURE_PASTE_SLEEP:-}" ]; then
      sleep "$TMUX_FIXTURE_PASTE_SLEEP"
    fi
    exit 0
    ;;
  send-keys)
    if [ -n "${TMUX_FIXTURE_SEND_SLEEP:-}" ]; then
      sleep "$TMUX_FIXTURE_SEND_SLEEP"
    fi
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
