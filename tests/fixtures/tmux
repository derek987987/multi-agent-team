#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  has-session)
    exit 0
    ;;
  list-panes)
    printf 'fake-session:frontend codex-aarch64-a 0 0 fake\n'
    ;;
  capture-pane)
    printf 'fake Codex pane waiting at prompt\n'
    ;;
  send-keys)
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
