#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  has-session)
    exit 0
    ;;
  list-panes)
    if [[ "$*" == *"#S:#W #{pane_current_command}"* ]]; then
      printf 'fake-session:frontend codex-aarch64-a 0 fixture-pane\n'
    elif [[ "$*" == *"#S:#W #{pane_pid}"* ]]; then
      printf 'fake-session:frontend fixture-pane\n'
    else
      printf 'fake-session\tfrontend\tcodex-aarch64-a\t0\tfixture-pane\n'
    fi
    ;;
  capture-pane)
    printf '%s\n' "${TMUX_FIXTURE_CAPTURE:-fake Codex pane waiting at prompt}"
    ;;
  load-buffer)
    exit 0
    ;;
  paste-buffer)
    if [ -n "${TMUX_FIXTURE_PASTE_SLEEP:-}" ]; then
      sleep "$TMUX_FIXTURE_PASTE_SLEEP"
    fi
    exit 0
    ;;
  send-keys)
    if [ -n "${TMUX_FIXTURE_SEND_SLEEP:-}" ]; then
      sleep "$TMUX_FIXTURE_SEND_SLEEP"
    fi
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
